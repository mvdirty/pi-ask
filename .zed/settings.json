{
	"format_on_save": "on",
	"ensure_final_newline_on_save": true,
	"remove_trailing_whitespace_on_save": true,
	"languages": {
		"TypeScript": {
			"formatter": {
				"external": {
					"command": "pnpm",
					"arguments": [
						"exec",
						"biome",
						"format",
						"--stdin-file-path",
						"{buffer_path}"
					]
				},
				"language_server": {
					"name": "biome"
				}
			},
			"hard_tabs": true,
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			}
		},
		"JSON": {
			"formatter": {
				"external": {
					"command": "pnpm",
					"arguments": [
						"exec",
						"biome",
						"format",
						"--stdin-file-path",
						"{buffer_path}"
					]
				}
			}
		},
		"JSONC": {
			"formatter": {
				"external": {
					"command": "pnpm",
					"arguments": [
						"exec",
						"biome",
						"format",
						"--stdin-file-path",
						"{buffer_path}"
					]
				}
			}
		},
		"JavaScript": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"TSX": {
			"code_actions_on_format": {
				"source.fixAll.biome": true,
				"source.organizeImports.biome": true
			},
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		}
	},
	"formatter": "language_server",
	"lsp": {
		"typescript-language-server": {
			"settings": {
				"typescript": {
					"preferences": {
						"includePackageJsonAutoImports": "on"
					}
				}
			}
		}
	}
}
